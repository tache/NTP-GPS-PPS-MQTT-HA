# GPSD Monitor Configuration
# Deploy to /etc/monitoring/gpsd_monitor.conf
# Set permissions: chmod 600 /etc/monitoring/gpsd_monitor.conf

MQTT_BROKER=<host>
MQTT_PORT=<port>
MQTT_USERNAME=<username>
MQTT_PASSWORD=<changeme>
MQTT_TLS=true
# MQTT_CA_CERT: path to a PEM CA certificate for TLS peer verification.
# Leave commented out to use the system trust store (e.g. Let's Encrypt certs work without this).
# Required only when your broker uses a self-signed or private CA certificate.
# Example: MQTT_CA_CERT=/etc/ssl/certs/my-broker-ca.pem
# MQTT_CA_CERT=

GPSD_HOST=localhost
GPSD_PORT=2947

# Message groups — one per GPSD message class
# Set to false to disable a group entirely (removes sensors from HA)
# Interval in seconds: 0 = publish every message, N = publish at most once every N seconds
GPS_PUBLISH_VERSION=true
GPS_PUBLISH_VERSION_INTERVAL=0

GPS_PUBLISH_SKY=true
GPS_PUBLISH_SKY_INTERVAL=5

GPS_PUBLISH_TPV=true
GPS_PUBLISH_TPV_INTERVAL=5

GPS_PUBLISH_TOFF=true
GPS_PUBLISH_TOFF_INTERVAL=10

GPS_PUBLISH_PPS=true
GPS_PUBLISH_PPS_INTERVAL=10
